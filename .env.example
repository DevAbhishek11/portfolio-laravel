# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="My Portfolio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=portfolio_user
DB_PASSWORD=

# ── Cache & Session ───────────────────────────────────────────────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Portfolio Config ──────────────────────────────────────────────────────────
PORTFOLIO_SITE_NAME="Your Name"
PORTFOLIO_TAGLINE="Full Stack Developer"
PORTFOLIO_EMAIL="hello@yourdomain.com"
PORTFOLIO_PHONE="+1 234 567 890"
PORTFOLIO_LOCATION="City, Country"
PORTFOLIO_META_DESC="Full Stack Developer specialising in Laravel and React"
PORTFOLIO_META_KEYWORDS="developer, laravel, react, portfolio"
PORTFOLIO_OG_IMAGE="/assets/images/og/default.jpg"

# ── Social Links ──────────────────────────────────────────────────────────────
PORTFOLIO_GITHUB="https://github.com/yourusername"
PORTFOLIO_LINKEDIN="https://linkedin.com/in/yourusername"
PORTFOLIO_TWITTER="https://twitter.com/yourusername"