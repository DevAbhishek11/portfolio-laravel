      "Bash(php -l app/Http/Controllers/Admin/BlogController.php)",
      "Bash(php -l app/Http/Controllers/Admin/ProjectController.php)",
      "Bash(curl -sS -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://127.0.0.1:8088/blogs)",
